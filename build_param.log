cmake -B build \
  -DBoost_DIR=/ucrt64/lib/cmake/Boost-1.90.0 \
  -Dspdlog_DIR=/ucrt64/lib/cmake/spdlog \
  -DHICAL_BUILD_TESTS=OFF \
  -DHICAL_BUILD_EXAMPLES=OFF
cmake --build build



使用方法
# 配置项目
cmake --preset default        # Debug 构建
cmake --preset release        # Release 构建
# 编译
cmake --build --preset default
cmake --build --preset release

# 包含的 Presets
Preset	类型	说明
default	Configure/Build	Debug 构建
release	Configure/Build	Release 构建（优化）



# 可用命令
cmake --preset list          # 列出所有可用 presets
cmake --preset <name>        # 使用指定 preset 配置
cmake --build --preset <name>  # 使用指定 preset 编译
