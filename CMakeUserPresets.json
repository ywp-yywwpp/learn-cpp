{
  "version": 8,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default Configure",
      "description": "Default configure preset using Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "Boost_DIR": "C:/msys64/ucrt64/lib/cmake/Boost-1.90.0",
        "spdlog_DIR": "C:/msys64/ucrt64/lib/cmake/spdlog",
        "HICAL_BUILD_TESTS": "OFF",
        "HICAL_BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release Configure",
      "description": "Release build with optimizations",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ]
}
